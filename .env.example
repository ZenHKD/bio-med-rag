# =============================================================================
# bio-med-rag — Environment Variables
# =============================================================================
# HOW TO USE:
#   cp .env.example .env
#   Fill in the values below.
#   .env is gitignored — never commit your keys.
# =============================================================================

# --- HuggingFace (required for HF encoder/decoder) -------------------------
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI (optional, only if using OpenAI encoder or decoder) ------------
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Cohere (optional, only if using Cohere reranker) ----------------------
# COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Logging ---------------------------------------------------------------
# Overrides configs/config.yaml logging.level
# LOG_LEVEL=INFO
