# =============================================================================
# bio-med-rag — Contributor Local Override
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp configs/config.local.yaml.example configs/config.local.yaml
#   2. Edit only the fields you want to override below.
#   3. config.local.yaml is gitignored — your changes stay local.
#   4. Put API keys in .env, NOT here.
# =============================================================================

# ---------------------------------------------------------------------------
# Example: Use a different encoder
# ---------------------------------------------------------------------------
# encoder:
#   model_name: "sentence-transformers/all-MiniLM-L6-v2"
#   device: cuda

# ---------------------------------------------------------------------------
# Example: Use OpenAI embeddings instead of HuggingFace
# ---------------------------------------------------------------------------
# encoder:
#   provider: openai
#   model_name: "text-embedding-3-small"

# ---------------------------------------------------------------------------
# Example: Use a larger local decoder with GPU
# ---------------------------------------------------------------------------
# decoder:
#   model_name: "BioMistral/BioMistral-7B"
#   device: cuda
#   generation:
#     max_new_tokens: 1024
#     temperature: 0.2

# ---------------------------------------------------------------------------
# Example: Use OpenAI as decoder
# ---------------------------------------------------------------------------
# decoder:
#   provider: openai
#   model_name: "gpt-4o-mini"
#   generation:
#     max_new_tokens: 512
#     temperature: 0.1

# ---------------------------------------------------------------------------
# Example: Enable reranker with cross-encoder
# ---------------------------------------------------------------------------
# reranker:
#   enabled: true
#   provider: cross_encoder
#   model_name: "cross-encoder/ms-marco-MiniLM-L-6-v2"
#   top_n: 3

# ---------------------------------------------------------------------------
# Example: Enable Cohere reranker (requires COHERE_API_KEY in .env)
# ---------------------------------------------------------------------------
# reranker:
#   enabled: true
#   provider: cohere
#   model_name: "rerank-english-v3.0"
#   top_n: 3

# ---------------------------------------------------------------------------
# Example: Change chunking for long clinical documents
# ---------------------------------------------------------------------------
# chunking:
#   chunk_size: 1024
#   chunk_overlap: 128

# ---------------------------------------------------------------------------
# Example: Increase retrieval top_k
# ---------------------------------------------------------------------------
# retriever:
#   top_k: 10

# ---------------------------------------------------------------------------
# Example: Switch vectorstore to FAISS
# ---------------------------------------------------------------------------
# vectorstore:
#   backend: faiss
#   persist_dir: data/vectorstore_faiss
